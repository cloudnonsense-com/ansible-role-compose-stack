{# ============ GRAFANA STACK ============ #}
---
services:

{# --- BEGIN: GRAFANA CONTAINER ---#}
{% with 
  container_name=compose_stack_name,
  image=compose_stack_grafana_image,
  restart=compose_stack_grafana_restart,
  manage_ports=compose_stack_grafana_manage_ports,
  ports=compose_stack_grafana_ports,

  manage_labels=compose_stack_grafana_manage_labels,
  labels_traefik_enable=compose_stack_grafana_labels_traefik_enable,
  labels_traefik_pattern=compose_stack_grafana_labels_traefik_pattern,
  labels_raw=compose_stack_grafana_labels_raw,
  labels_raw_enable=compose_stack_grafana_labels_raw_enable,

  manage_networks=compose_stack_manage_networks,
  networks=compose_stack_networks,
  manage_configs=compose_stack_grafana_manage_configs,
  configs=compose_stack_grafana_configs
%}
  {{ compose_stack_name }}:
{% include "includes/service_common.j2" %}
{% include "includes/service_logging.j2" %}
{% include "includes/service_ports.j2" %}
{% include "includes/service_labels.j2" %}
{% include "includes/service_networks.j2" %}
{% include "includes/service_configs.j2" %}
{% endwith %}
{# --- END:   GRAFANA CONTAINER ---#}

{# --- BEGIN: INFLUXDB CONTAINER ---#}
{% with 
  container_name="influxdb",
  image=compose_stack_influxdb_image,
  restart=compose_stack_influxdb_restart,
  manage_ports=compose_stack_influxdb_manage_ports,
  ports=compose_stack_influxdb_ports,

  manage_labels=compose_stack_influxdb_manage_labels,

  manage_networks=compose_stack_manage_networks,
  networks=compose_stack_networks,
  manage_configs=compose_stack_influxdb_manage_configs
%}
  influxdb:
{% include "includes/service_common.j2" %}
{% include "includes/service_logging.j2" %}
{% include "includes/service_ports.j2" %}
{% include "includes/service_labels.j2" %}
{% include "includes/service_networks.j2" %}
{% include "includes/service_configs.j2" %}
{% endwith %}
{# --- END:   INFLUXDB CONTAINER ---#}

{# --- BEGIN: GLOBALS ---#}
{% with 
  manage_networks=compose_stack_manage_networks,
  networks=compose_stack_networks,
  manage_configs=compose_stack_grafana_manage_configs,
  configs=compose_stack_grafana_configs
%}
{% include "includes/networks.j2" %}
{% include "includes/configs.j2" %}
{% endwith %}
{# --- END:   GLOBALS ---#}
...